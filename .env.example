# DevAssist AI Workspace — environment template (Phase 2)
# Copy to .env (root) for local overrides. Never commit real secrets.
# All keys use ASP.NET Core double-underscore convention (section__key).

# ──────────────────────────────────────────
# ASP.NET Core
# ──────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development

# ──────────────────────────────────────────
# SQL Server (matches docker-compose.yml SA password)
# ──────────────────────────────────────────
ConnectionStrings__DevAssistDb=Server=localhost,1433;Database=DevAssistDb;User Id=sa;Password=Your_strong_password123;TrustServerCertificate=True

# ──────────────────────────────────────────
# Azure OpenAI / Azure AI Foundry
# Leave ALL three empty → local heuristic fallbacks
# Standard Azure OpenAI: https://<resource>.openai.azure.com
# Azure AI Foundry serverless: https://<resource>.services.ai.azure.com/models/v1
# ──────────────────────────────────────────
AzureOpenAi__Endpoint=
AzureOpenAi__ApiKey=
AzureOpenAi__DeploymentName=
# Embedding model deployment (e.g. text-embedding-3-small, text-embedding-ada-002)
# Falls back to DeploymentName when empty (not recommended — set explicitly)
AzureOpenAi__EmbeddingDeploymentName=

# ──────────────────────────────────────────
# Azure AI Search
# Leave empty → SQL keyword retrieval fallback
# ──────────────────────────────────────────
AzureSearch__Endpoint=
AzureSearch__ApiKey=
AzureSearch__IndexName=devassist-documents
# Semantic ranker configuration name — leave empty to disable semantic re-ranking
# Requires Azure AI Search Standard tier or above with semantic search enabled
AzureSearch__SemanticConfigurationName=
# Embedding vector dimensions — must match your embedding model (1536 for ada-002 / text-embedding-3-small)
AzureSearch__VectorDimensions=1536

# ──────────────────────────────────────────
# Azure Blob Storage
# Leave empty → local filesystem (./data/documents)
# ──────────────────────────────────────────
BlobStorage__ConnectionString=
BlobStorage__ContainerName=documents

# ──────────────────────────────────────────
# Local file storage (used when BlobStorage is empty)
# ──────────────────────────────────────────
LocalFileStorage__RootPath=./data/documents

# ──────────────────────────────────────────
# Frontend
# Leave empty to use Vite dev proxy (/api → localhost:5147)
# ──────────────────────────────────────────
VITE_API_BASE_URL=
