# DevAssist AI Workspace — environment template
# Copy to .env (root) for local overrides. Never commit real secrets.

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development

# SQL Server (matches docker-compose.yml SA password)
ConnectionStrings__DevAssistDb=Server=localhost,1433;Database=DevAssistDb;User Id=sa;Password=Your_strong_password123;TrustServerCertificate=True

# Azure OpenAI — leave empty for local heuristic / grounded fallbacks
AzureOpenAi__Endpoint=
AzureOpenAi__ApiKey=
AzureOpenAi__DeploymentName=

# Azure AI Search — leave empty for SQL keyword retrieval fallback
AzureSearch__Endpoint=
AzureSearch__ApiKey=
AzureSearch__IndexName=devassist-documents

# Azure Blob Storage — leave empty for local filesystem (./data/documents)
BlobStorage__ConnectionString=
BlobStorage__ContainerName=documents

# Local file storage when blob connection is empty
LocalFileStorage__RootPath=./data/documents

# Frontend — leave empty to use Vite dev proxy (/api → localhost:5147)
VITE_API_BASE_URL=
