{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "ConnectionStrings": {
    "DevAssistDb": "Server=localhost,14333;Database=DevAssistDb;User Id=sa;Password=Your_strong_password123;TrustServerCertificate=True"
  },
  "AzureOpenAi": {
    "Endpoint": "",
    "ApiKey": "",
    "DeploymentName": ""
  },
  "AzureSearch": {
    "Endpoint": "",
    "ApiKey": "",
    "IndexName": "devassist-documents"
  },
  "BlobStorage": {
    "ConnectionString": "",
    "ContainerName": "documents"
  },
  "LocalFileStorage": {
    "RootPath": "./data/documents"
  },
  "AllowedHosts": "*"
}
